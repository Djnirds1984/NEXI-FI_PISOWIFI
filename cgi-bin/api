#!/bin/ash

# PisoWiFi API CGI Script
# Compatible with BusyBox Ash shell

# Set content type
echo "Content-Type: application/json"
echo ""

# Read query string
QUERY_STRING="$QUERY_STRING"

# Extract action parameter
ACTION=""
for param in $(echo "$QUERY_STRING" | tr '&' '\n'); do
    case "$param" in
        action=*)
            ACTION=$(echo "$param" | cut -d'=' -f2)
            ;;
    esac
done

# Read POST data if available
if [ "$REQUEST_METHOD" = "POST" ]; then
    read -r POST_DATA
fi

# Get Content-Type header for multipart form data
CONTENT_TYPE="$CONTENT_TYPE"

# Function to output JSON response
json_response() {
    local success="$1"
    local message="$2"
    local data="$3"
    
    echo "{"
    echo "  \"success\": $success,"
    echo "  \"message\": \"$message\""
    if [ -n "$data" ]; then
        echo ", $data"
    fi
    echo "}"
}

# Function to get system status
get_status() {
    local hostname=$(uci get system.@system[0].hostname 2>/dev/null || echo "OpenWrt")
    local uptime=$(uptime | awk '{print $1,$2,$3}')
    local wan_ip=$(ifconfig wan 2>/dev/null | grep 'inet addr' | awk '{print $2}' | cut -d: -f2 || echo "N/A")
    local lan_ip=$(ifconfig br-lan 2>/dev/null | grep 'inet addr' | awk '{print $2}' | cut -d: -f2 || echo "N/A")
    
    local data="\"data\": {"
    data="$data \"hostname\": \"$hostname\","
    data="$data \"uptime\": \"$uptime\","
    data="$data \"wan_ip\": \"$wan_ip\","
    data="$data \"lan_ip\": \"$lan_ip\""
    data="$data }"
    
    json_response "true" "Status retrieved successfully" "$data"
}

# Function to get comprehensive WiFi settings (LuCI-style)
get_wifi() {
    # Get 2.4GHz WiFi settings
    local wifi2g_disabled=$(uci get wireless.radio0.disabled 2>/dev/null || echo "0")
    local wifi2g_ssid=$(uci get wireless.@wifi-iface[0].ssid 2>/dev/null || echo "OpenWrt")
    local wifi2g_key=$(uci get wireless.@wifi-iface[0].key 2>/dev/null || echo "")
    local wifi2g_encryption=$(uci get wireless.@wifi-iface[0].encryption 2>/dev/null || echo "none")
    local wifi2g_channel=$(uci get wireless.radio0.channel 2>/dev/null || echo "auto")
    local wifi2g_txpower=$(uci get wireless.radio0.txpower 2>/dev/null || echo "20")
    
    # Get 5GHz WiFi settings
    local wifi5g_disabled=$(uci get wireless.radio1.disabled 2>/dev/null || echo "1")
    local wifi5g_ssid=$(uci get wireless.@wifi-iface[1].ssid 2>/dev/null || echo "OpenWrt_5G")
    local wifi5g_key=$(uci get wireless.@wifi-iface[1].key 2>/dev/null || echo "")
    local wifi5g_encryption=$(uci get wireless.@wifi-iface[1].encryption 2>/dev/null || echo "none")
    local wifi5g_channel=$(uci get wireless.radio1.channel 2>/dev/null || echo "auto")
    local wifi5g_txpower=$(uci get wireless.radio1.txpower 2>/dev/null || echo "20")
    
    # Check if WiFi modules are enabled (robust detection)
    local wifi2g_module_enabled="0"
    local wifi5g_module_enabled="0"
    if uci show wireless 2>/dev/null | grep -q "radio0"; then
        wifi2g_module_enabled="1"
    fi
    if uci show wireless 2>/dev/null | grep -q "radio1"; then
        wifi5g_module_enabled="1"
    fi
    # Fallback to sysfs if UCI sections are missing
    if [ "$wifi2g_module_enabled" = "0" ] && [ -d "/sys/class/ieee80211/phy0" ]; then
        wifi2g_module_enabled="1"
    fi
    if [ "$wifi5g_module_enabled" = "0" ] && [ -d "/sys/class/ieee80211/phy1" ]; then
        wifi5g_module_enabled="1"
    fi
    
    local data="\"data\": {"
    data="$data \"wifi2g_enabled\": \"$([ \"$wifi2g_disabled\" = \"0\" ] && echo \"1\" || echo \"0\")\","
    data="$data \"wifi2g_ssid\": \"$wifi2g_ssid\","
    data="$data \"wifi2g_key\": \"$wifi2g_key\","
    data="$data \"wifi2g_encryption\": \"$wifi2g_encryption\","
    data="$data \"wifi2g_channel\": \"$wifi2g_channel\","
    data="$data \"wifi2g_txpower\": \"$wifi2g_txpower\","
    data="$data \"wifi2g_module_enabled\": \"$wifi2g_module_enabled\","
    data="$data \"wifi5g_enabled\": \"$([ \"$wifi5g_disabled\" = \"0\" ] && echo \"1\" || echo \"0\")\","
    data="$data \"wifi5g_ssid\": \"$wifi5g_ssid\","
    data="$data \"wifi5g_key\": \"$wifi5g_key\","
    data="$data \"wifi5g_encryption\": \"$wifi5g_encryption\","
    data="$data \"wifi5g_channel\": \"$wifi5g_channel\","
    data="$data \"wifi5g_txpower\": \"$wifi5g_txpower\","
    data="$data \"wifi5g_module_enabled\": \"$wifi5g_module_enabled\""
    data="$data }"
    
    json_response "true" "WiFi settings retrieved successfully" "$data"
}

# Function to set comprehensive WiFi settings (LuCI-style)
set_wifi() {
    if [ -z "$POST_DATA" ]; then
        json_response "false" "No data provided"
        return
    fi
    
    # Extract 2.4GHz settings
    local wifi2g_enabled=$(echo "$POST_DATA" | sed -n 's/.*"wifi2g_enabled":"\([^"]*\)".*/\1/p')
    local wifi2g_ssid=$(echo "$POST_DATA" | sed -n 's/.*"wifi2g_ssid":"\([^"]*\)".*/\1/p')
    local wifi2g_key=$(echo "$POST_DATA" | sed -n 's/.*"wifi2g_key":"\([^"]*\)".*/\1/p')
    local wifi2g_encryption=$(echo "$POST_DATA" | sed -n 's/.*"wifi2g_encryption":"\([^"]*\)".*/\1/p')
    local wifi2g_channel=$(echo "$POST_DATA" | sed -n 's/.*"wifi2g_channel":"\([^"]*\)".*/\1/p')
    local wifi2g_txpower=$(echo "$POST_DATA" | sed -n 's/.*"wifi2g_txpower":"\([^"]*\)".*/\1/p')
    
    # Extract 5GHz settings
    local wifi5g_enabled=$(echo "$POST_DATA" | sed -n 's/.*"wifi5g_enabled":"\([^"]*\)".*/\1/p')
    local wifi5g_ssid=$(echo "$POST_DATA" | sed -n 's/.*"wifi5g_ssid":"\([^"]*\)".*/\1/p')
    local wifi5g_key=$(echo "$POST_DATA" | sed -n 's/.*"wifi5g_key":"\([^"]*\)".*/\1/p')
    local wifi5g_encryption=$(echo "$POST_DATA" | sed -n 's/.*"wifi5g_encryption":"\([^"]*\)".*/\1/p')
    local wifi5g_channel=$(echo "$POST_DATA" | sed -n 's/.*"wifi5g_channel":"\([^"]*\)".*/\1/p')
    local wifi5g_txpower=$(echo "$POST_DATA" | sed -n 's/.*"wifi5g_txpower":"\([^"]*\)".*/\1/p')
    
    # Update 2.4GHz settings if radio0 exists
    if uci show wireless | grep -q "radio0"; then
        if [ -n "$wifi2g_enabled" ]; then
            if [ "$wifi2g_enabled" = "1" ]; then
                uci set wireless.radio0.disabled="0"
            else
                uci set wireless.radio0.disabled="1"
            fi
        fi
        
        if [ -n "$wifi2g_ssid" ]; then
            uci set wireless.@wifi-iface[0].ssid="$wifi2g_ssid"
        fi
        
        if [ -n "$wifi2g_key" ]; then
            uci set wireless.@wifi-iface[0].key="$wifi2g_key"
        fi
        
        if [ -n "$wifi2g_encryption" ]; then
            uci set wireless.@wifi-iface[0].encryption="$wifi2g_encryption"
        fi
        
        if [ -n "$wifi2g_channel" ]; then
            uci set wireless.radio0.channel="$wifi2g_channel"
        fi
        
        if [ -n "$wifi2g_txpower" ]; then
            uci set wireless.radio0.txpower="$wifi2g_txpower"
        fi
    fi
    
    # Update 5GHz settings if radio1 exists
    if uci show wireless | grep -q "radio1"; then
        if [ -n "$wifi5g_enabled" ]; then
            if [ "$wifi5g_enabled" = "1" ]; then
                uci set wireless.radio1.disabled="0"
            else
                uci set wireless.radio1.disabled="1"
            fi
        fi
        
        if [ -n "$wifi5g_ssid" ]; then
            uci set wireless.@wifi-iface[1].ssid="$wifi5g_ssid"
        fi
        
        if [ -n "$wifi5g_key" ]; then
            uci set wireless.@wifi-iface[1].key="$wifi5g_key"
        fi
        
        if [ -n "$wifi5g_encryption" ]; then
            uci set wireless.@wifi-iface[1].encryption="$wifi5g_encryption"
        fi
        
        if [ -n "$wifi5g_channel" ]; then
            uci set wireless.radio1.channel="$wifi5g_channel"
        fi
        
        if [ -n "$wifi5g_txpower" ]; then
            uci set wireless.radio1.txpower="$wifi5g_txpower"
        fi
    fi
    
    # Commit changes
    uci commit wireless
    
    # Restart WiFi service
    wifi reload 2>/dev/null || true
    /etc/init.d/network restart 2>/dev/null || true
    
    json_response "true" "WiFi settings updated successfully"
}

# Function to get license settings
get_license() {
    local centralized_key=$(uci get pisowifi.config.centralized_key 2>/dev/null || echo "")
    
    local data="\"data\": {"
    data="$data \"centralized_key\": \"$centralized_key\""
    data="$data }"
    
    json_response "true" "License settings retrieved successfully" "$data"
}

# Function to set license settings
set_license() {
    if [ -z "$POST_DATA" ]; then
        json_response "false" "No data provided"
        return
    fi
    
    # Extract centralized key from JSON
    local centralized_key=$(echo "$POST_DATA" | sed -n 's/.*"centralized_key":"\([^"]*\)".*/\1/p')
    
    # Create pisowifi config section if it doesn't exist
    if ! uci show pisowifi 2>/dev/null | grep -q "pisowifi.config"; then
        uci add pisowifi config
        uci rename pisowifi.@config[-1]=config
    fi
    
    # Set license key
    uci set pisowifi.config.centralized_key="$centralized_key"
    uci commit pisowifi
    
    json_response "true" "License settings updated successfully"
}

# Function to get sales data
get_sales() {
    # Mock sales data - replace with actual data from your system
    local today_sales="150.00"
    local total_sessions="25"
    
    # Try to read from actual sales log if available
    if [ -f "/tmp/pisowifi_sales.log" ]; then
        today_sales=$(tail -1 /tmp/pisowifi_sales.log | awk -F',' '{print $2}' 2>/dev/null || echo "150.00")
        total_sessions=$(wc -l < /tmp/pisowifi_sales.log 2>/dev/null || echo "25")
    fi
    
    local data="\"data\": {"
    data="$data \"today_sales\": \"$today_sales\","
    data="$data \"total_sessions\": \"$total_sessions\""
    data="$data }"
    
    json_response "true" "Sales data retrieved successfully" "$data"
}

# Function to change admin password
change_admin_password() {
    if [ -z "$POST_DATA" ]; then
        json_response "false" "No data provided"
        return
    fi
    
    # Extract passwords from JSON
    local current_password=$(echo "$POST_DATA" | sed -n 's/.*"current_password":"\([^"]*\)".*/\1/p')
    local new_password=$(echo "$POST_DATA" | sed -n 's/.*"new_password":"\([^"]*\)".*/\1/p')
    
    if [ -z "$current_password" ] || [ -z "$new_password" ]; then
        json_response "false" "Both current and new passwords are required"
        return
    fi
    
    # Check if current password is correct (this is a basic implementation)
    # In a real implementation, you would check against a stored password hash
    local stored_password=$(uci get pisowifi.admin.password 2>/dev/null || echo "admin")
    
    if [ "$current_password" != "$stored_password" ]; then
        json_response "false" "Current password is incorrect"
        return
    fi
    
    # Create admin config section if it doesn't exist
    if ! uci show pisowifi 2>/dev/null | grep -q "pisowifi.admin"; then
        uci add pisowifi admin
        uci rename pisowifi.@admin[-1]=admin
    fi
    
    # Update password
    uci set pisowifi.admin.password="$new_password"
    uci commit pisowifi
    
    json_response "true" "Admin password changed successfully"
}

# Function to handle firmware flash
flash_firmware() {
    # Check if multipart form data contains firmware file
    if [ -z "$POST_DATA" ]; then
        json_response "false" "No firmware file uploaded"
        return
    fi
    
    # Extract boundary from Content-Type header
    local boundary=$(echo "$CONTENT_TYPE" | sed -n 's/.*boundary=\([^;]*\).*/\1/p')
    
    if [ -z "$boundary" ]; then
        json_response "false" "Invalid multipart form data"
        return
    fi
    
    # Create temporary directory for firmware processing
    local temp_dir="/tmp/pisowifi_firmware"
    mkdir -p "$temp_dir"
    
    # Extract firmware file from multipart data
    # This is a simplified implementation - in production, use proper multipart parsing
    local firmware_file="$temp_dir/firmware.bin"
    
    # Look for firmware data in the POST body
    echo "$POST_DATA" | sed -n '/Content-Disposition: form-data; name="firmware"/,/------/p' | head -n -1 | tail -n +2 > "$firmware_file"
    
    # Validate firmware file
    if [ ! -f "$firmware_file" ] || [ ! -s "$firmware_file" ]; then
        rm -rf "$temp_dir"
        json_response "false" "Failed to extract firmware file"
        return
    fi
    
    # Check minimum file size (should be at least 1MB for OpenWrt firmware)
    local file_size=$(stat -c%s "$firmware_file" 2>/dev/null || echo "0")
    if [ "$file_size" -lt 1048576 ]; then
        rm -rf "$temp_dir"
        json_response "false" "Firmware file too small (minimum 1MB required)"
        return
    fi
    
    # Validate firmware magic bytes (basic check for common firmware formats)
    local magic=$(hexdump -C "$firmware_file" | head -1 | awk '{print $2$3$4$5}')
    local is_valid_firmware=false
    
    # Check for common firmware signatures
    case "$magic" in
        "27051956"|"1f8b0800"|"4c5a4950"|"75737461")  # Common firmware signatures
            is_valid_firmware=true
            ;;
    esac
    
    if [ "$is_valid_firmware" != "true" ]; then
        rm -rf "$temp_dir"
        json_response "false" "Invalid firmware file format"
        return
    fi
    
    # Create a marker file to indicate firmware flash in progress
    echo "flash_in_progress" > /tmp/pisowifi_flash_in_progress
    
    # Save firmware to standard location
    cp "$firmware_file" /tmp/openwrt-firmware.bin
    
    # Clean up temporary directory
    rm -rf "$temp_dir"
    
    # Schedule the actual flash operation with sysupgrade
    # Use nohup to ensure it continues even if the web connection drops
    (
        sleep 5
        /sbin/sysupgrade -F /tmp/openwrt-firmware.bin
    ) > /dev/null 2>&1 &
    
    json_response "true" "Firmware flash initiated. Router will reboot in 30 seconds. Please wait 5 minutes before accessing again."
}

# Main action dispatcher
case "$ACTION" in
    "get_status")
        get_status
        ;;
    "get_wifi")
        get_wifi
        ;;
    "set_wifi")
        set_wifi
        ;;
    "get_license")
        get_license
        ;;
    "set_license")
        set_license
        ;;
    "get_sales")
        get_sales
        ;;
    "change_admin_password")
        change_admin_password
        ;;
    "flash_firmware")
        flash_firmware
        ;;
    *)
        json_response "false" "Invalid action: $ACTION"
        ;;
esac
