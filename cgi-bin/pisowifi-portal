#!/usr/bin/env ucode
'use strict';

import { getenv, exit } from 'env';
import { stdin, stdout } from 'fs';
import { uci } from 'uci';
import { cursor } from 'uci';

const c = cursor();
c.load('pisowifi');
c.load('wireless');
c.load('network');

const content_type = 'text/html';
stdout.write(`Content-Type: ${content_type}\r\n\r\n`);

function get_client_ip() {
    const remote_addr = getenv('REMOTE_ADDR') || '192.168.1.100';
    return remote_addr;
}

function get_mac_address(ip) {
    return '00:11:22:33:44:55';
}

function generate_session_id() {
    return Math.random().toString(36).substr(2, 9);
}

function get_current_time() {
    return Math.floor(Date.now() / 1000);
}

function is_session_valid(session_id) {
    return false;
}

function create_session(mac_address, ip_address, duration) {
    const session_id = generate_session_id();
    const start_time = get_current_time();
    const end_time = start_time + (duration * 60);
    
    return {
        session_id: session_id,
        mac_address: mac_address,
        ip_address: ip_address,
        start_time: start_time,
        end_time: end_time,
        active: true
    };
}

function get_portal_settings() {
    return {
        enabled: c.get('pisowifi', 'general', 'enabled') === '1',
        title: c.get('pisowifi', 'landing_page', 'landing_title') || 'Welcome to PisoWiFi',
        message: c.get('pisowifi', 'landing_page', 'landing_message') || 'Please insert coin or pay to access the internet',
        price_per_hour: parseInt(c.get('pisowifi', 'general', 'price_per_hour') || '5'),
        currency: c.get('pisowifi', 'general', 'currency') || 'PHP',
        payment_method: c.get('pisowifi', 'payment', 'payment_method') || 'coinslot',
        qr_code_image: c.get('pisowifi', 'payment', 'qr_code_image') || '',
        gcash_number: c.get('pisowifi', 'payment', 'gcash_number') || ''
    };
}

function generate_landing_page(settings, client_ip, session_id) {
    const bg_image = settings.landing_background ? `background-image: url('${settings.landing_background}'); background-size: cover;` : '';
    const logo_html = settings.landing_logo ? `<img src="${settings.landing_logo}" alt="Logo" style="max-width: 200px; margin-bottom: 20px;"><br>` : '';
    
    return `<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${settings.title}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            ${bg_image}
        }
        .container {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            text-align: center;
            max-width: 500px;
            width: 90%;
        }
        .title {
            color: #333;
            font-size: 28px;
            margin-bottom: 20px;
            font-weight: bold;
        }
        .message {
            color: #666;
            font-size: 16px;
            margin-bottom: 30px;
            line-height: 1.5;
        }
        .price-info {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin: 20px 0;
            border-left: 4px solid #007bff;
        }
        .price {
            font-size: 24px;
            font-weight: bold;
            color: #007bff;
            margin-bottom: 10px;
        }
        .payment-methods {
            margin: 30px 0;
        }
        .payment-option {
            background: #007bff;
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            margin: 10px;
            transition: background 0.3s;
        }
        .payment-option:hover {
            background: #0056b3;
        }
        .qr-code {
            margin: 20px 0;
            text-align: center;
        }
        .qr-code img {
            max-width: 200px;
            border: 2px solid #ddd;
            border-radius: 10px;
        }
        .gcash-info {
            background: #e3f2fd;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            border-left: 4px solid #2196f3;
        }
        .client-info {
            background: #fff3cd;
            padding: 10px;
            border-radius: 5px;
            margin: 15px 0;
            font-size: 14px;
            color: #856404;
        }
        .footer {
            margin-top: 30px;
            font-size: 12px;
            color: #999;
        }
        .coin-slot {
            background: #28a745;
            color: white;
            border: none;
            padding: 20px 40px;
            border-radius: 10px;
            font-size: 18px;
            cursor: pointer;
            margin: 20px 0;
            transition: background 0.3s;
        }
        .coin-slot:hover {
            background: #1e7e34;
        }
        .voucher-input {
            width: 100%;
            padding: 15px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            margin: 10px 0;
            box-sizing: border-box;
        }
        .voucher-submit {
            background: #ffc107;
            color: #212529;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            margin: 10px 0;
            transition: background 0.3s;
        }
        .voucher-submit:hover {
            background: #e0a800;
        }
    </style>
</head>
<body>
    <div class="container">
        ${logo_html}
        <div class="title">${settings.title}</div>
        <div class="message">${settings.message}</div>
        
        <div class="client-info">
            Your IP: ${client_ip}
        </div>
        
        <div class="price-info">
            <div class="price">${settings.price_per_hour} ${settings.currency} per hour</div>
            <div>Access to high-speed internet</div>
        </div>
        
        <div class="payment-methods">
            ${settings.payment_method === 'coinslot' || settings.payment_method === 'both' ? `
                <button class="coin-slot" onclick="handleCoinPayment()">
                    💰 Insert Coin for 1 Hour Access
                </button>
            ` : ''}
            
            ${settings.payment_method === 'qr_code' || settings.payment_method === 'both' ? `
                <div class="qr-payment">
                    <h3>Scan to Pay</h3>
                    ${settings.qr_code_image ? `<div class="qr-code"><img src="${settings.qr_code_image}" alt="QR Code"></div>` : ''}
                    ${settings.gcash_number ? `<div class="gcash-info">GCash: ${settings.gcash_number}</div>` : ''}
                    <button class="payment-option" onclick="handleQRPayment()">
                        📱 Pay via QR Code
                    </button>
                </div>
            ` : ''}
        </div>
        
        <div style="margin-top: 30px;">
            <h3>Have a Voucher?</h3>
            <input type="text" class="voucher-input" id="voucherCode" placeholder="Enter voucher code">
            <br>
            <button class="voucher-submit" onclick="handleVoucherPayment()">
                🎟️ Redeem Voucher
            </button>
        </div>
        
        <div class="footer">
            PisoWiFi Management System | Powered by LuCI
        </div>
    </div>
    
    <script>
        function handleCoinPayment() {
            fetch('pisowifi-portal?action=coin_payment&session=${session_id}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    client_ip: '${client_ip}',
                    duration: 60
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Payment successful! You now have internet access for 1 hour.');
                    window.location.href = data.redirect_url || 'http://www.google.com';
                } else {
                    alert('Payment failed. Please try again.');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Payment processing error. Please contact support.');
            });
        }
        
        function handleQRPayment() {
            fetch('pisowifi-portal?action=qr_payment&session=${session_id}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    client_ip: '${client_ip}',
                    duration: 60
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Payment verified! You now have internet access for 1 hour.');
                    window.location.href = data.redirect_url || 'http://www.google.com';
                } else {
                    alert('Payment verification failed. Please complete payment and try again.');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Payment verification error. Please contact support.');
            });
        }
        
        function handleVoucherPayment() {
            const voucherCode = document.getElementById('voucherCode').value;
            if (!voucherCode) {
                alert('Please enter a voucher code.');
                return;
            }
            
            fetch('pisowifi-portal?action=voucher_payment&session=${session_id}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    client_ip: '${client_ip}',
                    voucher_code: voucherCode
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Voucher redeemed successfully! You now have internet access.');
                    window.location.href = data.redirect_url || 'http://www.google.com';
                } else {
                    alert('Invalid voucher code. Please check and try again.');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Voucher processing error. Please contact support.');
            });
        }
        
        // Auto-refresh every 30 seconds to check if session is still valid
        setInterval(function() {
            fetch('pisowifi-portal?action=check_session&session=${session_id}')
                .then(response => response.json())
                .then(data => {
                    if (data.authenticated) {
                        window.location.href = data.redirect_url || 'http://www.google.com';
                    }
                })
                .catch(error => {
                    console.error('Session check error:', error);
                });
        }, 30000);
    </script>
</body>
</html>`;
}

function main() {
    const client_ip = get_client_ip();
    const settings = get_portal_settings();
    
    if (!settings.enabled) {
        stdout.write('<!DOCTYPE html><html><body><h1>Captive Portal Disabled</h1></body></html>');
        return;
    }
    
    const session_id = generate_session_id();
    const html = generate_landing_page(settings, client_ip, session_id);
    
    stdout.write(html);
}

main();