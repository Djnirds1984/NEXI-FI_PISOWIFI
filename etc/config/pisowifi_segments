config segment 'premium'
	option enabled '1'
	option name 'Premium'
	option description 'High-speed premium tier'
	option wifi_device 'radio0'
	option ssid 'PisoWiFi_Premium'
	option ssid_suffix '_Premium'
	option encryption 'psk2'
	option key 'PremiumPass123'
	option hidden '0'
	option isolate '0'
	option max_clients '50'
	option vlan_id '10'
	option ip_range '192.168.10.100-192.168.10.200'
	option subnet_mask '255.255.255.0'
	option gateway '192.168.10.1'
	option dns_primary '8.8.8.8'
	option dns_secondary '8.8.4.4'
	option bandwidth_down '50'
	option bandwidth_up '25'
	option session_timeout '120'
	option idle_timeout '60'
	option daily_quota '0'
	option pricing_tier 'premium'
	option custom_price '20.00'
	option auth_method 'voucher'
	option voucher_prefix 'PREM'
	list allowed_domains 'google.com,facebook.com,youtube.com'
	option landing_page_html ''
	option enable_logging '1'
	option enable_qos '1'
	option enable_firewall '1'
	option enable_mac_filter '0'
	option enable_time_restrictions '0'

