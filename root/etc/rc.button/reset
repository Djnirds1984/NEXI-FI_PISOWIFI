#!/bin/sh

[ "$ACTION" = "pressed" ] || exit 0

DB_FILE="/etc/pisowifi/pisowifi.db"
[ -d /etc/pisowifi ] || mkdir -p /etc/pisowifi
chmod 777 /etc/pisowifi 2>/dev/null || true

LOCK_FILE="/tmp/coin_lock"
LOCK_TIMEOUT="$(uci get pisowifi.settings.coin_lock_timeout 2>/dev/null)"
[ -z "$LOCK_TIMEOUT" ] && LOCK_TIMEOUT=20
NOW="$(date +%s)"

LINE="$(cat "$LOCK_FILE" 2>/dev/null | tr -d '\r\n')"
LOCKED_MAC="$(echo "$LINE" | awk '{print $1}')"
LOCK_EXP="$(echo "$LINE" | awk '{print $2}')"
[ -z "$LOCK_EXP" ] && LOCK_EXP=0
if [ -z "$LOCKED_MAC" ] || [ "$LOCK_EXP" -le "$NOW" ] 2>/dev/null; then
	rm -f "$LOCK_FILE" 2>/dev/null
	exit 0
fi
echo "$LOCKED_MAC $((NOW + LOCK_TIMEOUT))" > "$LOCK_FILE" 2>/dev/null

sqlite3 $DB_FILE "INSERT INTO coins (mac, coins) VALUES ('$LOCKED_MAC', 1)" 2>/dev/null
COUNT=$(sqlite3 $DB_FILE "SELECT COALESCE(SUM(coins),0) FROM coins WHERE mac='$LOCKED_MAC'" 2>/dev/null)

logger -t pisowifi "Coin inserted for $LOCKED_MAC via ${BUTTON:-reset} button. Total: $COUNT"

chmod 666 $DB_FILE
